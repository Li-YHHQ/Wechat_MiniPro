<!-- pages/detail/detail.wxml -->
<view wx:if="{{item}}" class="detail-page">

  <text class="title">{{item.name}}</text>

  <!-- 历史背景 -->
  <view class="stage-card">
    <text class="stage-title">历史背景</text>
    <view class="stage-content">
      <image src="{{item.history.img}}" mode="aspectFill" class="stage-img" />
      <text class="stage-desc">{{item.history.desc}}</text>
    </view>
  </view>

  <!-- 建筑特色 -->
  <view class="stage-card">
    <text class="stage-title">建筑特色</text>
    <view class="stage-content">
      <image src="{{item.feature.img}}" mode="aspectFill" class="stage-img" />
      <text class="stage-desc">{{item.feature.desc}}</text>
    </view>
  </view>

  <!-- 现代价值 -->
  <view class="stage-card">
    <text class="stage-title">现代价值</text>
    <view class="stage-content">
      <image src="{{item.value.img}}" mode="aspectFill" class="stage-img" />
      <text class="stage-desc">{{item.value.desc}}</text>
    </view>
  </view>

</view>

<view wx:else class="empty">
  <text>加载中...</text>
</view>
