<!-- pages/detail/index.wxml -->
<view class="page">

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="sk-header">
      <view class="sk-title"></view>
      <view class="sk-badge"></view>
    </view>
    <view class="sk-card">
      <view class="sk-row" wx:for="{{6}}" wx:key="*this">
        <view class="sk-label"></view>
        <view class="sk-value"></view>
      </view>
    </view>
  </view>

  <!-- 详情 / 编辑 -->
  <block wx:elif="{{drug}}">

    <!-- 药品名称头部 -->
    <view class="drug-header">
      <view class="drug-name-row">
        <text class="drug-name">{{drug.drug_name}}</text>
        <view class="status-badge {{(drug.current_stock ?? drug.stock_quantity ?? 0) > (drug.low_stock_threshold ?? 0) ? 'ok' : 'warn'}}">
          <text>{{(drug.current_stock ?? drug.stock_quantity ?? 0) > (drug.low_stock_threshold ?? 0) ? '库存充足' : '库存不足'}}</text>
        </view>
      </view>
      <text class="drug-generic" wx:if="{{drug.generic_name}}">通用名：{{drug.generic_name}}</text>
    </view>

    <!-- 基本信息卡片 -->
    <view class="info-card">
      <view class="section-title">基本信息</view>

      <block wx:if="{{!editing}}">
        <view class="info-row">
          <text class="info-label">药品编码</text>
          <text class="info-value">{{drug.drug_code || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">规格</text>
          <text class="info-value">{{drug.specifications || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">单位</text>
          <text class="info-value">{{drug.unit || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">分类</text>
          <text class="info-value">{{drug.category || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">生产厂家</text>
          <text class="info-value">{{drug.manufacturer || '-'}}</text>
        </view>
      </block>

      <block wx:else>
        <view class="edit-row">
          <text class="info-label">药品编码</text>
          <input class="edit-input" value="{{form.drug_code}}" placeholder="请输入药品编码" data-field="drug_code" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">药品名称</text>
          <input class="edit-input" value="{{form.drug_name}}" placeholder="请输入药品名称" data-field="drug_name" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">通用名</text>
          <input class="edit-input" value="{{form.generic_name}}" placeholder="请输入通用名" data-field="generic_name" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">规格</text>
          <input class="edit-input" value="{{form.specifications}}" placeholder="如：500mg×20片" data-field="specifications" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">单位</text>
          <input class="edit-input" value="{{form.unit}}" placeholder="如：盒、瓶" data-field="unit" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">分类</text>
          <input class="edit-input" value="{{form.category}}" placeholder="请输入分类" data-field="category" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">生产厂家</text>
          <input class="edit-input" value="{{form.manufacturer}}" placeholder="请输入生产厂家" data-field="manufacturer" bindinput="onFormInput" />
        </view>
      </block>
    </view>

    <!-- 价格库存卡片 -->
    <view class="info-card">
      <view class="section-title">价格 &amp; 库存</view>

      <block wx:if="{{!editing}}">
        <view class="info-row">
          <text class="info-label">进货价</text>
          <text class="info-value price">¥{{drug.cost_price != null ? drug.cost_price : '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">零售价</text>
          <text class="info-value price accent">¥{{drug.retail_price != null ? drug.retail_price : '-'}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">当前库存</text>
          <text class="info-value">{{drug.current_stock ?? drug.stock_quantity ?? '--'}} {{drug.unit}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">预警阈值</text>
          <text class="info-value">{{drug.low_stock_threshold != null ? drug.low_stock_threshold : '-'}} {{drug.unit}}</text>
        </view>
      </block>

      <block wx:else>
        <view class="edit-row">
          <text class="info-label">进货价</text>
          <input class="edit-input" type="digit" value="{{form.cost_price}}" placeholder="0.00" data-field="cost_price" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">零售价</text>
          <input class="edit-input" type="digit" value="{{form.retail_price}}" placeholder="0.00" data-field="retail_price" bindinput="onFormInput" />
        </view>
        <view class="edit-row">
          <text class="info-label">预警阈值</text>
          <input class="edit-input" type="number" value="{{form.low_stock_threshold}}" placeholder="最低库存数量" data-field="low_stock_threshold" bindinput="onFormInput" />
        </view>
      </block>
    </view>

    <!-- 底部按钮 -->
    <view class="action-bar">
      <block wx:if="{{!editing}}">
        <view class="btn btn-delete" bindtap="onDelete">
          <text>删除</text>
        </view>
        <view class="btn btn-primary" bindtap="onEdit">
          <text>编辑</text>
        </view>
      </block>
      <block wx:else>
        <view class="btn btn-cancel" bindtap="onCancelEdit">
          <text>取消</text>
        </view>
        <view class="btn btn-primary {{saving ? 'disabled' : ''}}" bindtap="onSave">
          <text>{{saving ? '保存中...' : '保存'}}</text>
        </view>
      </block>
    </view>

  </block>

  <!-- 加载失败 -->
  <view wx:elif="{{!loading}}" class="empty-state">
    <text class="empty-icon">⚠️</text>
    <text class="empty-text">数据加载失败</text>
  </view>

  <view style="height: calc(120rpx + env(safe-area-inset-bottom));"></view>
</view>
