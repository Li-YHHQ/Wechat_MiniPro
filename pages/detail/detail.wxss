/* pages/detail/detail.wxss */
.detail-page {
  padding: 32rpx;
  background: #F5F0E8;
  min-height: 100vh;
}

.title {
  font-size: 48rpx;
  color: #3D2B1F;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 40rpx;
}

.stage-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(139,69,19,0.08);
}

.stage-title {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #C8A96E;
  padding-left: 16rpx;
}

.stage-content {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.stage-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.stage-desc {
  flex: 1;
  font-size: 26rpx;
  color: #3D2B1F;
  line-height: 44rpx;
  margin-left: 20rpx;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #8C7B6B;
}
