/* pages/stock/stockout-add/index.wxss */
.page {
  background: #F0F9FF;
  min-height: 100vh;
  padding-top: 16rpx;
}

.form-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin: 0 16rpx 16rpx;
  padding: 0 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(14,165,233,0.06);
}

.section-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #0EA5E9;
  padding: 20rpx 0 12rpx;
  border-bottom: 1rpx solid #F1F5F9;
  letter-spacing: 1rpx;
}

/* 药品搜索 */
.drug-search-wrap {
  padding: 16rpx 0;
}

.drug-search-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F1F5F9;
  border-radius: 12rpx;
  padding: 0 20rpx;
  height: 80rpx;
  gap: 12rpx;
}

.search-icon-txt {
  font-size: 28rpx;
  flex-shrink: 0;
}

.drug-input {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  height: 80rpx;
  line-height: 80rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.drug-dropdown {
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  border-radius: 12rpx;
  margin-top: 8rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  overflow: hidden;
}

.dropdown-hint {
  padding: 24rpx;
  font-size: 26rpx;
  color: #94A3B8;
  text-align: center;
}

.drug-result-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F8FAFC;
}

.drug-result-item:last-child { border-bottom: none; }
.drug-result-item:active { background: #F0F9FF; }

.result-name {
  font-size: 28rpx;
  color: #0F172A;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-spec {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #F8FAFC;
}

.form-row.last { border-bottom: none; }

.form-label {
  font-size: 28rpx;
  color: #374151;
  width: 160rpx;
  flex-shrink: 0;
}

.required { color: #EF4444; }

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  text-align: right;
  height: 88rpx;
  line-height: 88rpx;
}

.form-placeholder {
  color: #CBD5E1;
  font-size: 26rpx;
}

/* Picker */
.picker-value {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  font-size: 28rpx;
  color: #0F172A;
  flex: 1;
  text-align: right;
  min-height: 88rpx;
  line-height: 88rpx;
}

.picker-arrow {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 提交按钮 */
.submit-wrap {
  padding: 24rpx 16rpx;
}

.submit-btn {
  height: 96rpx;
  background: #F59E0B;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(245,158,11,0.3);
}

.submit-btn.disabled {
  background: #FCD34D;
  box-shadow: none;
}
