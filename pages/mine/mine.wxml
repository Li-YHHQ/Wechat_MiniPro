<!-- pages/mine/mine.wxml -->
<view class="mine-page">

  <!-- 顶部用户信息 -->
  <view class="user-header">
    <image class="avatar" src="https://picsum.photos/120/120?random=99" mode="aspectFill" />
    <text class="username">游客用户</text>
  </view>

  <!-- 功能菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="onMenuTap" data-item="我的足迹">
      <text class="menu-label">我的足迹</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-item="意见反馈">
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onMenuTap" data-item="关于我们">
      <text class="menu-label">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item last">
      <text class="menu-label">版本信息</text>
      <text class="menu-version">v1.0.0</text>
    </view>
  </view>

  <!-- 版权 -->
  <text class="copyright">© 2026 宫墙导览</text>

</view>
