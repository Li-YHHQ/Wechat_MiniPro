/* pages/mine/mine.wxss */
.mine-page {
  min-height: 100vh;
  background: #F5F0E8;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 40rpx;
  box-sizing: border-box;
}

.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #E8DDD0;
  margin-bottom: 20rpx;
}

.username {
  font-size: 32rpx;
  color: #3D2B1F;
  font-weight: 500;
}

.menu-list {
  width: 100%;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(139,69,19,0.08);
  margin-bottom: 60rpx;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #E8DDD0;
}

.menu-item.last {
  border-bottom: none;
}

.menu-label {
  font-size: 30rpx;
  color: #3D2B1F;
}

.menu-arrow {
  font-size: 36rpx;
  color: #8C7B6B;
}

.menu-version {
  font-size: 28rpx;
  color: #8C7B6B;
}

.copyright {
  font-size: 24rpx;
  color: #8C7B6B;
  margin-top: auto;
}
