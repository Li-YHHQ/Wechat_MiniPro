<!-- pages/mine/index.wxml -->
<view class="page">

  <!-- 渐变 Hero + 用户卡 -->
  <view class="hero">
    <view class="blob blob-1"></view>
    <view class="blob blob-2"></view>

    <view class="hero-content">
      <text class="hero-title">设置</text>

      <view class="user-card glass">
        <view class="avatar-wrap">
          <text class="avatar-emoji">👨‍⚕️</text>
        </view>
        <view class="user-info">
          <text class="user-name">{{userInfo.displayName}}</text>
          <view class="role-chip">
            <text>{{userInfo.role}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 菜单分组 -->
  <view class="content">

    <view class="menu-group">
      <view class="menu-item" bindtap="goToPassword">
        <view class="menu-icon-wrap tint-blue"><text>🔑</text></view>
        <text class="menu-label">修改密码</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon-wrap tint-emerald"><text>🏪</text></view>
        <text class="menu-label">店铺信息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon-wrap tint-amber"><text>🔔</text></view>
        <text class="menu-label">消息通知</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item">
        <view class="menu-icon-wrap tint-violet"><text>❓</text></view>
        <text class="menu-label">帮助与反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item last">
        <view class="menu-icon-wrap tint-slate"><text>ℹ️</text></view>
        <text class="menu-label">关于</text>
        <text class="menu-version">v1.0.0</text>
      </view>
    </view>

    <view class="logout-wrap">
      <view class="logout-btn" bindtap="onLogout">
        <text class="logout-icon">↪</text>
        <text>退出登录</text>
      </view>
    </view>

    <text class="footer-text">© 2026 药店管理系统</text>
  </view>

  <view style="height: calc(140rpx + env(safe-area-inset-bottom));"></view>
</view>
