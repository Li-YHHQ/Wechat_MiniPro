/* pages/mine/index.wxss */
.page {
  background: #F0F9FF;
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.user-card {
  background: linear-gradient(135deg, #0EA5E9, #0284C7);
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 32rpx;
}

.user-avatar {
  font-size: 80rpx;
  background: rgba(255,255,255,0.2);
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 100rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.user-role {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: block;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 12rpx rgba(14,165,233,0.08);
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 36rpx 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
  gap: 20rpx;
}

.menu-item.last {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  width: 44rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #0F172A;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CBD5E1;
}

.menu-version {
  font-size: 26rpx;
  color: #94A3B8;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #FFF1F2;
  color: #EF4444;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  line-height: 96rpx;
}

.logout-btn::after {
  border: none;
}
