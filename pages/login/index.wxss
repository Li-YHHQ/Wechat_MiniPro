/* pages/login/index.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #0EA5E9 0%, #0284C7 40%, #F0F9FF 40%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 60rpx;
  box-sizing: border-box;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.logo-icon {
  font-size: 100rpx;
  line-height: 1;
  margin-bottom: 20rpx;
}

.logo-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.logo-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  letter-spacing: 2rpx;
}

.form-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(14,165,233,0.15);
}

.form-item {
  display: flex;
  flex-direction: column;
  margin-bottom: 8rpx;
}

.form-label {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  height: 88rpx;
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #0F172A;
  border: 2rpx solid #E2E8F0;
}

.input-placeholder {
  color: #CBD5E1;
  font-size: 28rpx;
}

.divider {
  height: 32rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: #0EA5E9;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-top: 48rpx;
  line-height: 96rpx;
  letter-spacing: 4rpx;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: #7DD3FC;
}

.footer-tip {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #94A3B8;
}
