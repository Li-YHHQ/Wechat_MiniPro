/* pages/dashboard/index.wxss */
page {
  background: #F2F7FB;
}

.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 渐变 Hero ========== */
.hero {
  position: relative;
  padding: 64rpx 32rpx 140rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 45%, #22D3EE 100%);
  overflow: hidden;
  border-bottom-left-radius: 48rpx;
  border-bottom-right-radius: 48rpx;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0) 50%, rgba(255,255,255,0.06) 100%);
  pointer-events: none;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  opacity: 0.45;
  pointer-events: none;
}

.blob-1 {
  width: 360rpx;
  height: 360rpx;
  background: #A7F3D0;
  top: -120rpx;
  right: -100rpx;
}

.blob-2 {
  width: 280rpx;
  height: 280rpx;
  background: #BAE6FD;
  bottom: -80rpx;
  left: -60rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.hero-greet {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  letter-spacing: 0.5rpx;
}

.hero-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 10rpx;
  display: block;
}

/* 玻璃质感 */
.glass {
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.35);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.4),
    0 16rpx 40rpx -8rpx rgba(2,132,199,0.35);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* 今日卡片：浮在 Hero 底部 */
.today-card {
  margin-top: 40rpx;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  position: relative;
}

.today-tag {
  position: absolute;
  top: -22rpx;
  left: 32rpx;
  background: #FFFFFF;
  color: #0EA5E9;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 12rpx rgba(14,165,233,0.25);
}

.today-grid {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 8rpx;
}

.today-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.today-divider {
  width: 1rpx;
  height: 70rpx;
  background: rgba(255,255,255,0.4);
  margin: 0 16rpx;
}

.today-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  display: block;
  margin-bottom: 8rpx;
}

.today-value {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.today-num {
  font-size: 44rpx;
  font-weight: 700;
  margin-left: 4rpx;
  letter-spacing: 0.5rpx;
}

/* ========== 统计卡片网格 ========== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 24rpx;
  margin-top: -80rpx;
  position: relative;
  z-index: 3;
}

.stat-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(15,23,42,0.08);
  border: 1rpx solid rgba(226,232,240,0.6);
}

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stat-icon {
  font-size: 38rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #0F172A;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

/* 颜色 tint */
.tint-cyan  { background: linear-gradient(135deg, #CFFAFE, #A5F3FC); }
.tint-blue  { background: linear-gradient(135deg, #DBEAFE, #BFDBFE); }
.tint-amber { background: linear-gradient(135deg, #FEF3C7, #FDE68A); }
.tint-rose  { background: linear-gradient(135deg, #FFE4E6, #FECDD3); }

/* 骨架屏 */
.skeleton-card {
  height: 140rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
  border: none;
}

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========== 区块标题 ========== */
.section-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
  position: relative;
  padding-left: 18rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 6rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #0EA5E9, #22D3EE);
}

.section-link {
  font-size: 24rpx;
  color: #0EA5E9;
}

/* ========== 本月卡片 ========== */
.month-card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: row;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(15,23,42,0.08);
  border: 1rpx solid rgba(226,232,240,0.6);
}

.month-cell {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
}

.month-cell + .month-cell {
  border-left: 1rpx solid #F1F5F9;
  padding-left: 24rpx;
}

.month-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.month-sales  { background: linear-gradient(135deg, #DBEAFE, #93C5FD); }
.month-profit { background: linear-gradient(135deg, #D1FAE5, #6EE7B7); }

.month-label {
  font-size: 22rpx;
  color: #94A3B8;
  display: block;
  margin-bottom: 6rpx;
}

.month-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #0F172A;
}

/* ========== 7 天柱状图 ========== */
.chart-card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 28rpx 24rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(15,23,42,0.08);
  border: 1rpx solid rgba(226,232,240,0.6);
}

.chart-empty {
  text-align: center;
  color: #94A3B8;
  font-size: 24rpx;
  padding: 40rpx 0;
}

.chart-wrap {
  height: 240rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.chart-bars {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  height: 100%;
  gap: 12rpx;
}

.chart-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.chart-bar-fill {
  width: 100%;
  background: linear-gradient(180deg, #38BDF8, #0EA5E9);
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  transition: height 0.4s ease;
  min-height: 8rpx;
}

.chart-bar-fill.empty {
  background: #E2E8F0;
}

.chart-x {
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 12rpx;
}

/* ========== 快捷入口 ========== */
.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.shortcut-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 8rpx 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 6rpx 16rpx -6rpx rgba(15,23,42,0.08);
  border: 1rpx solid rgba(226,232,240,0.6);
}

.shortcut-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.shortcut-text {
  font-size: 22rpx;
  color: #475569;
  text-align: center;
  font-weight: 500;
}
