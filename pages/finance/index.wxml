<!-- pages/finance/index.wxml -->
<view class="page">

  <!-- 日期范围选择器 -->
  <view class="date-bar">
    <view class="date-picker-wrap">
      <text class="date-label">开始日期</text>
      <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
        <view class="date-value">
          <text>{{startDate}}</text>
          <text class="date-arrow">▾</text>
        </view>
      </picker>
    </view>
    <text class="date-sep">—</text>
    <view class="date-picker-wrap">
      <text class="date-label">结束日期</text>
      <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
        <view class="date-value">
          <text>{{endDate}}</text>
          <text class="date-arrow">▾</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton-wrap">
    <view class="sk-stat-grid">
      <view class="sk-stat-card" wx:for="{{4}}" wx:key="*this">
        <view class="sk-line sk-lg"></view>
        <view class="sk-line sk-sm" style="margin-top:16rpx;"></view>
      </view>
    </view>
    <view class="sk-detail-list">
      <view class="sk-detail-row" wx:for="{{5}}" wx:key="*this">
        <view class="sk-line sk-md"></view>
        <view class="sk-line sk-sm"></view>
        <view class="sk-line sk-sm"></view>
      </view>
    </view>
  </view>

  <block wx:elif="{{summary}}">

    <!-- 汇总卡片 -->
    <view class="summary-grid">
      <view class="summary-card blue">
        <text class="summary-label">总销售额</text>
        <view class="summary-value-row">
          <text class="summary-unit">¥</text>
          <text class="summary-value">{{summary.totalSales}}</text>
        </view>
      </view>
      <view class="summary-card green">
        <text class="summary-label">总成本</text>
        <view class="summary-value-row">
          <text class="summary-unit">¥</text>
          <text class="summary-value">{{summary.totalCost}}</text>
        </view>
      </view>
      <view class="summary-card amber">
        <text class="summary-label">毛利润</text>
        <view class="summary-value-row">
          <text class="summary-unit">¥</text>
          <text class="summary-value">{{summary.grossProfit}}</text>
        </view>
      </view>
      <view class="summary-card purple">
        <text class="summary-label">毛利率</text>
        <view class="summary-value-row">
          <text class="summary-value">{{summary.grossMargin}}</text>
          <text class="summary-unit">%</text>
        </view>
      </view>
    </view>

    <!-- 每日明细 -->
    <view wx:if="{{details.length}}" class="detail-card">
      <view class="detail-header">
        <text class="detail-col date-col">日期</text>
        <text class="detail-col num-col">销售额</text>
        <text class="detail-col num-col">成本</text>
        <text class="detail-col num-col">利润</text>
      </view>
      <view class="detail-row" wx:for="{{details}}" wx:key="_date">
        <text class="detail-col date-col">{{item._date}}</text>
        <text class="detail-col num-col">{{item._sales}}</text>
        <text class="detail-col num-col">{{item._cost}}</text>
        <text class="detail-col num-col {{item._profit >= 0 ? 'profit-pos' : 'profit-neg'}}">{{item._profit}}</text>
      </view>
    </view>

    <!-- 无明细 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">📊</text>
      <text class="empty-text">该时段暂无明细数据</text>
    </view>

  </block>

  <!-- 首次加载前空状态 -->
  <view wx:elif="{{!loading}}" class="empty-state">
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无数据</text>
  </view>

  <view style="height: calc(100rpx + env(safe-area-inset-bottom));"></view>
</view>
