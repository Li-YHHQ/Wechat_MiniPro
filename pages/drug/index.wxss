/* pages/drug/index.wxss */
page {
  background: #F2F7FB;
}

.page {
  min-height: 100vh;
}

/* ========== 渐变 Hero ========== */
.hero {
  position: relative;
  padding: 36rpx 32rpx 80rpx;
  background: linear-gradient(135deg, #0EA5E9 0%, #38BDF8 45%, #22D3EE 100%);
  overflow: hidden;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
}

.blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(40rpx);
  opacity: 0.45;
  pointer-events: none;
}

.blob-1 {
  width: 320rpx;
  height: 320rpx;
  background: #A7F3D0;
  top: -120rpx;
  right: -100rpx;
}

.blob-2 {
  width: 240rpx;
  height: 240rpx;
  background: #BAE6FD;
  bottom: -60rpx;
  left: -60rpx;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  display: block;
  letter-spacing: 0.5rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
  display: block;
}

/* 玻璃搜索框 */
.glass {
  background: rgba(255,255,255,0.22);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow:
    inset 0 1rpx 0 rgba(255,255,255,0.4),
    0 8rpx 24rpx -8rpx rgba(2,132,199,0.35);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.search-bar {
  margin-top: 32rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 24rpx;
  height: 80rpx;
  border-radius: 999rpx;
  gap: 12rpx;
  transition: all 0.25s ease;
}

.search-bar.focused {
  background: #FFFFFF;
}

.search-icon {
  font-size: 30rpx;
  flex-shrink: 0;
  opacity: 0.85;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #0F172A;
  height: 80rpx;
  line-height: 80rpx;
}

.search-placeholder {
  color: rgba(255,255,255,0.85);
  font-size: 28rpx;
}

.search-bar.focused .search-placeholder {
  color: #94A3B8;
}

.search-clear {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.search-bar.focused .search-clear {
  color: #64748B;
  background: #F1F5F9;
}

/* ========== 骨架屏 ========== */
.skeleton-list {
  padding: 24rpx 24rpx 0;
  margin-top: -40rpx;
  position: relative;
  z-index: 3;
}

.skeleton-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(15,23,42,0.08);
}

.sk-left {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
  flex-shrink: 0;
}

.sk-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.sk-line {
  height: 28rpx;
  background: linear-gradient(90deg, #E2E8F0 25%, #F1F5F9 50%, #E2E8F0 75%);
  background-size: 200% 100%;
  border-radius: 8rpx;
  animation: shimmer 1.2s infinite;
}

.sk-line-lg { width: 60%; }
.sk-line-sm { width: 40%; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: 20rpx;
}

.empty-icon-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0F2FE, #CFFAFE);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx -12rpx rgba(14,165,233,0.35);
}

.empty-icon {
  font-size: 100rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748B;
  font-weight: 500;
  margin-top: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #94A3B8;
}

/* ========== 列表 ========== */
.list {
  padding: 0 24rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 3;
}

.list-item {
  background: #FFFFFF;
  border-radius: 22rpx;
  padding: 26rpx 22rpx;
  margin-bottom: 18rpx;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 22rpx;
  box-shadow: 0 8rpx 24rpx -8rpx rgba(15,23,42,0.08);
  border: 1rpx solid rgba(226,232,240,0.6);
  transition: transform 0.15s ease;
}

.list-item:active {
  transform: scale(0.985);
}

/* 左侧首字图标 */
.item-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.6);
}

.item-initial {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
  line-height: 1;
}

.t-cyan    { background: linear-gradient(135deg, #22D3EE, #06B6D4); }
.t-blue    { background: linear-gradient(135deg, #60A5FA, #3B82F6); }
.t-amber   { background: linear-gradient(135deg, #FBBF24, #F59E0B); }
.t-rose    { background: linear-gradient(135deg, #FB7185, #F43F5E); }
.t-violet  { background: linear-gradient(135deg, #A78BFA, #8B5CF6); }
.t-emerald { background: linear-gradient(135deg, #34D399, #10B981); }

/* 中间信息 */
.item-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #0F172A;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.status-badge {
  flex-shrink: 0;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.5;
}

.status-badge.ok {
  background: #D1FAE5;
  color: #059669;
}

.status-badge.warn {
  background: #FEE2E2;
  color: #DC2626;
}

.item-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  overflow: hidden;
}

.item-spec,
.item-manuf {
  font-size: 24rpx;
  color: #64748B;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-manuf {
  color: #94A3B8;
  flex: 1;
  min-width: 0;
}

.item-bottom {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 4rpx;
}

.category-chip {
  background: #EFF6FF;
  color: #0EA5E9;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 240rpx;
}

.item-price-row {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 14rpx;
  flex-shrink: 0;
}

.price-tag {
  font-size: 28rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.stock-tag {
  font-size: 22rpx;
  color: #94A3B8;
}

/* ========== 加载更多 ========== */
.load-more {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.load-more-text {
  font-size: 22rpx;
  color: #94A3B8;
}

.dot-loader {
  display: inline-flex;
  flex-direction: row;
  gap: 10rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #0EA5E9;
  animation: bounce 0.9s infinite ease-in-out both;
}

.dot:nth-child(2) { animation-delay: 0.15s; }
.dot:nth-child(3) { animation-delay: 0.3s; }

@keyframes bounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.5; }
  40%           { transform: translateY(-8rpx); opacity: 1; }
}

/* ========== 浮动新增按钮 ========== */
.fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0EA5E9, #22D3EE);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 16rpx 32rpx -8rpx rgba(14,165,233,0.55),
    inset 0 2rpx 0 rgba(255,255,255,0.4);
  z-index: 10;
  transition: transform 0.15s ease;
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  line-height: 1;
  font-weight: 300;
}
