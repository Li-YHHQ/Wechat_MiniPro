<!-- pages/drug/index.wxml -->
<view class="page">

  <!-- 渐变 Hero + 搜索 -->
  <view class="hero">
    <view class="blob blob-1"></view>
    <view class="blob blob-2"></view>
    <view class="hero-content">
      <view class="hero-row">
        <view>
          <text class="hero-title">药品管理</text>
          <text class="hero-sub">共收录 {{total || 0}} 种药品</text>
        </view>
      </view>

      <!-- 玻璃质感搜索框 -->
      <view class="search-bar glass {{searchFocused ? 'focused' : ''}}">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索药品名称、编码"
          placeholder-class="search-placeholder"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
          bindfocus="onSearchFocus"
          bindblur="onSearchBlur"
          confirm-type="search"
        />
        <text wx:if="{{searchKeyword}}" class="search-clear" bindtap="onSearchClear">✕</text>
      </view>
    </view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton-list">
    <view class="skeleton-item" wx:for="{{6}}" wx:key="*this">
      <view class="sk-left"></view>
      <view class="sk-right">
        <view class="sk-line sk-line-lg"></view>
        <view class="sk-line sk-line-sm"></view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{!list.length}}" class="empty-state">
    <view class="empty-icon-wrap">
      <text class="empty-icon">💊</text>
    </view>
    <text class="empty-text">{{searchKeyword ? '未找到相关药品' : '暂无药品数据'}}</text>
    <text wx:if="{{!searchKeyword}}" class="empty-hint">点击右下角 + 添加第一款药品</text>

    <!-- 临时诊断面板 -->
    <view wx:if="{{debug}}" class="diag-panel">
      <text class="diag-title">诊断信息</text>
      <view class="diag-row"><text class="diag-k">请求结果</text><text class="diag-v {{debug.ok ? 'diag-ok' : 'diag-err'}}">{{debug.ok ? '成功' : '失败'}}</text></view>
      <view class="diag-row"><text class="diag-k">本地 token</text><text class="diag-v {{debug.hasToken ? 'diag-ok' : 'diag-err'}}">{{debug.hasToken ? '存在' : '不存在'}}</text></view>
      <view wx:if="{{debug.ok}}" class="diag-row"><text class="diag-k">total</text><text class="diag-v">{{debug.total}}</text></view>
      <view wx:if="{{debug.ok}}" class="diag-row"><text class="diag-k">list 长度</text><text class="diag-v">{{debug.listLen}}</text></view>
      <view wx:if="{{!debug.ok}}" class="diag-row"><text class="diag-k">HTTP</text><text class="diag-v">{{debug.statusCode || '—'}}</text></view>
      <view wx:if="{{!debug.ok}}" class="diag-row"><text class="diag-k">错误信息</text><text class="diag-v diag-err">{{debug.errMsg}}</text></view>
      <view class="diag-row"><text class="diag-k">耗时</text><text class="diag-v">{{debug.elapsedMs}}ms</text></view>
    </view>
  </view>

  <!-- 列表 -->
  <view wx:else class="list">
    <view
      class="list-item"
      wx:for="{{list}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <!-- 左侧图标 -->
      <view class="item-icon-wrap {{item._tint}}">
        <text class="item-initial">{{item._initial}}</text>
      </view>

      <!-- 中间信息 -->
      <view class="item-main">
        <view class="item-top">
          <text class="item-name">{{item._name}}</text>
          <view class="status-badge {{item._statusOk ? 'ok' : 'warn'}}">
            <text>{{item._statusLabel}}</text>
          </view>
        </view>

        <view class="item-meta">
          <text wx:if="{{item._spec}}" class="item-spec">{{item._spec}}</text>
          <text wx:if="{{item._manuf}}" class="item-manuf">{{item._manuf}}</text>
        </view>

        <view class="item-bottom">
          <view wx:if="{{item._category}}" class="category-chip">{{item._category}}</view>
          <view class="item-price-row">
            <text class="price-tag">¥{{item._retail}}</text>
            <text class="stock-tag">阈值 {{item._stockMin}} {{item.unit || ''}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <view class="dot-loader">
        <view class="dot"></view><view class="dot"></view><view class="dot"></view>
      </view>
    </view>
    <view class="load-more" wx:elif="{{!hasMore && list.length}}">
      <text class="load-more-text">— 已加载全部 {{total}} 条 —</text>
    </view>
  </view>

  <!-- 浮动新增按钮 -->
  <view class="fab" bindtap="goToAdd">
    <text class="fab-icon">＋</text>
  </view>

  <view style="height: calc(120rpx + env(safe-area-inset-bottom));"></view>
</view>
