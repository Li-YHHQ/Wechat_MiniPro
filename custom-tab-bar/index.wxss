.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #F5F0E8;
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #E8DDD0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  color: #8C7B6B;
  margin-top: 4rpx;
}

.tab-item.active .tab-text {
  color: #8B4513;
  font-weight: bold;
}
