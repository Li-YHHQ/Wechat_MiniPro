.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: row;
  border-top: 1rpx solid #E2E8F0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 9999;
  box-shadow: 0 -2rpx 12rpx rgba(14,165,233,0.08);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1;
}

.tab-text {
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.tab-item.active .tab-text {
  color: #0EA5E9;
  font-weight: bold;
}
